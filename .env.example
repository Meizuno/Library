# --- required ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/postgres
REDIS_URL=redis://localhost:6379/0
# JWT_SECRET_KEY must be at least 32 bytes (HS256 minimum). Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-me-with-at-least-32-bytes-of-random-secret

# --- general (optional, with sensible defaults) ---
CACHE_TTL=300
LOG_LEVEL=INFO
LOG_FORMAT=console

# --- JWT / tokens (optional) ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
VERIFICATION_TOKEN_TTL_HOURS=24

# Used to build the verification URL sent in welcome emails:
#   {APP_BASE_URL}/members/verify?token=...
APP_BASE_URL=http://localhost:8000

# --- email / SMTP (optional) ---
# Without SMTP_HOST, the EmailNotifier logs the email instead of sending
# it. No SMTP server required to run locally.
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=library@example.com
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
